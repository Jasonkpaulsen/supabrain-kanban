{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Campaign Intelligence Platform",
  "version": "0.1.0",
  "identifier": "com.worldwright.cip",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Campaign Intelligence Platform",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Local-first AI campaign memory for TTRPG DMs",
    "longDescription": "Records and transcribes your TTRPG sessions, then maintains a cross-linked campaign wiki — NPCs, quests, locations, plot threads — fully offline. One-time purchase.",
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}

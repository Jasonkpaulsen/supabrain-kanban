{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Campaign Intelligence Platform",
  "version": "0.1.0",
  "identifier": "com.worldwright.cip",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Campaign Intelligence Platform",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "category": "Productivity",
    "shortDescription": "Local-first AI campaign memory for TTRPG DMs",
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
